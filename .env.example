# Telegram bot tokeni (@BotFather dan oling)
BOT_TOKEN=123456789:AAExampleTokenHere

# PostgreSQL ma'lumotlar bazasi URL
# Railway: avtomatik beriladi (RAILWAY_DATABASE_URL)
# O'zingiz qo'shayotgan bo'lsangiz:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Admin Telegram chat ID (ixtiyoriy)
ADMIN_CHAT_ID=123456789

# Veb-server porti (Railway/Render avtomatik belgilaydi)
WEB_PORT=3000

# Tashqi URL — deploy bo'lgandan keyin to'ldiring (Excel fallback uchun)
# Masalan Railway: https://magazin-bot.up.railway.app
# Masalan Render:  https://magazin-bot.onrender.com
WEB_URL=https://your-domain.com
