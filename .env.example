# Telegram bot tokeni (@BotFather dan oling)
BOT_TOKEN=123456789:AAExampleTokenHere

# Ma'lumotlar bazasi (SQLite fayl manzili)
DATABASE_URL="file:./dev.db"

# Admin Telegram chat ID (ixtiyoriy — DB dagi barcha userlar ham oladi)
ADMIN_CHAT_ID=123456789

# Veb-server porti (default: 3000)
WEB_PORT=3000

# Tashqi URL — deploy qilingandan keyin to'ldiring (Excel fallback uchun)
# Masalan Railway: https://magazin-bot.up.railway.app
# Masalan Render:  https://magazin-bot.onrender.com
WEB_URL=https://your-domain.com
